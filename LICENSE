from typing import Dict, Optional
import re
from datetime import datetime
import requests
from bs4 import BeautifulSoup
from urllib.parse import quote

# Base de connaissances initiale
base_connaissances = {
    "UE": {
        "vin": {
            "droits_douane": "10-20% selon le degré d'alcool",
            "documents": "Certificat sanitaire, facture pro forma, étiquetage en langue locale",
            "restrictions": "Taux d'alcool maximal: 15% vol.",
            "dernière_mise_a_jour": "2025-11-01"
        },
        "whisky": {
            "droits_douane": "12-25% selon le degré d'alcool",
            "documents": "Certificat d'origine, licence d'importation",
            "restrictions": "Interdiction si taux > 55% vol.",
            "dernière_mise_a_jour": "2025-11-01"
        }
    },
    "Royaume-Uni": {
        "vin": {
            "droits_douane": "£2.23 par bouteille (taux 2026)",
            "documents": "Licence d'importation, certificat d'origine",
            "restrictions": "Accises supplémentaires si > 22% vol.",
            "dernière_mise_a_jour": "2026-01-15"
        },
        "whisky": {
            "droits_douane": "£28.74/litre d'alcool pur",
            "documents": "Licence d'importation, certificat d'origine",
            "restrictions": "Interdiction si taux > 55% vol.",
            "dernière_mise_a_jour": "2026-01-15"
        }
    },
    "Cameroun": {
        "vin": {
            "droits_douane": "30% + TVA",
            "documents": "Certificat de conformité CEEAC, licence d'importation",
            "restrictions": "Interdiction si taux > 60% vol.",
            "dernière_mise_a_jour": "2026-01-01"
        },
        "whisky": {
            "droits_douane": "35% + TVA",
            "documents": "Certificat de conformité CEEAC, licence d'importation",
            "restrictions": "Interdiction si taux > 50% vol.",
            "dernière_mise_a_jour": "2026-01-01"
        }
    }
}

# Sources officielles
sources_officielles = {
    "UE": {
        "nom": "Commission Européenne",
        "url_base": "https://ec.europa.eu/taxation_customs",
        "mots_clés_recherche": ["alcohol", "duties", "import", "2026", "wine", "whisky"]
    },
    "Royaume-Uni": {
        "nom": "GOV.UK",
        "url_base": "https://www.gov.uk",
        "mots_clés_recherche": ["import", "alcohol", "duties", "2026", "wine", "whisky"]
    },
    "Cameroun": {
        "nom": "Douanes camerounaises",
        "url_base": "http://www.douanes.cm",
        "mots_clés_recherche": ["droits", "alcool", "importation", "2026"]
    }
}

class AgentDouaneAlcool:
    def __init__(self):
        self.base_connaissances = base_connaissances

    def extraire_droits_douane(self, texte: str) -> str:
        match = re.search(r"droits[\\s\\w%]+\\d+%|£?\\d+(\\.\\d+)?\\s*(par|par|litre|bouteille)", texte, re.IGNORECASE)
        return match.group(0).strip() if match else "Non spécifié"

    def extraire_documents(self, texte: str) -> str:
        match = re.search(r"documents[\\s\\w,]+(?=\\srestrictions|$|\\n)", texte, re.IGNORECASE)
        return match.group(0).strip() if match else "Non spécifiés"

    def extraire_restrictions(self, texte: str) -> str:
        match = re.search(r"restrictions[\\s\\w%>]+(?=\\sdernière|$|\\n)", texte, re.IGNORECASE)
        return match.group(0).strip() if match else "Aucune"

    def rechercher_infos_web(self, pays: str, type_alcool: str) -> Optional[str]:
        if pays not in sources_officielles:
            return None
        mots_clés = sources_officielles[pays]["mots_clés_recherche"]
        mots_clés.append(type_alcool)
        requête = "+".join(mots_clés)
        url = f"{sources_officielles[pays]['url_base']}/search?q={quote(requête)}"
        try:
            headers = {"User-Agent": "Mozilla/5.0"}
            response = requests.get(url, headers=headers, timeout=10)
            response.raise_for_status()
            soup = BeautifulSoup(response.text, 'html.parser')
            contenu = soup.find("main") or soup.find("div", class_="content") or soup
            return contenu.get_text(separator="\n", strip=True)
        except Exception as e:
            print(f"Erreur recherche web pour {pays}: {e}")
            return None

    def rechercher_regles(self, pays: str, type_alcool: str) -> Optional[Dict]:
        règles = self.base_connaissances.get(pays, {}).get(type_alcool)
        if règles and datetime.strptime(règles["dernière_mise_a_jour"], "%Y-%m-%d") > datetime(2025, 12, 31):
            return règles
        texte_web = self.rechercher_infos_web(pays, type_alcool)
        if texte_web:
            droits = self.extraire_droits_douane(texte_web)
            documents = self.extraire_documents(texte_web)
            restrictions = self.extraire_restrictions(texte_web)
            if any(x in ["Non spécifié", "Aucune", "Non spécifiés"] for x in [droits, documents, restrictions]):
                return None
            règles_web = {
                "droits_douane": droits,
                "documents": documents,
                "restrictions": restrictions,
                "dernière_mise_a_jour": datetime.now().strftime("%Y-%m-%d")
            }
            if pays not in self.base_connaissances:
                self.base_connaissances[pays] = {}
            self.base_connaissances[pays][type_alcool] = règles_web
            return règles_web
        return None

    def répondre_question(self, question: str) -> str:
        pays_cible = None
        type_alcool = None
        if "UE" in question or "Europe" in question:
            pays_cible = "UE"
        elif "Royaume-Uni" in question or "Grande-Bretagne" in question or "UK" in question:
            pays_cible = "Royaume-Uni"
        elif "Cameroun" in question:
            pays_cible = "Cameroun"
        if "vin" in question:
            type_alcool = "vin"
        elif "whisky" in question or "alcool fort" in question:
            type_alcool = "whisky"
        if not pays_cible or not type_alcool:
            return "Pays ou type d'alcool non reconnu."
        règles = self.rechercher_regles(pays_cible, type_alcool)
        if not règles:
            return f"Aucune règle trouvée pour {type_alcool} vers {pays_cible}."
        réponse = (
            f"Règles pour exporter du {type_alcool} vers {pays_cible} (mis à jour le {règles['dernière_mise_a_jour']}):\n"
            f"- **Droits de douane** : {règles['droits_douane']}\n"
            f"- **Documents requis** : {règles['documents']}\n"
            f"- **Restrictions** : {règles['restrictions']}"
        )
        return réponse

# Exemple d'utilisation
if __name__ == "__main__":
    agent = AgentDouaneAlcool()
    while True:
        question = input("Posez une question (ex: 'Quels sont les droits de douane pour exporter du whisky vers le Cameroun ?') : ")
        print(agent.répondre_question(question))MIT License

